TELEGRAM_BOT_TOKEN=put_your_bot_token_here
ALLOWED_TELEGRAM_USER_IDS=123456789
APP_ENV=production
ENABLE_DEV_AUTH=false
TELEGRAM_INIT_DATA_MAX_AGE_SECONDS=300
API_RATE_LIMIT_READS=120
API_RATE_LIMIT_MUTATIONS=30
BUSINESS_TIMEZONE=Europe/Moscow
DATABASE_PATH=data/trading_bot.sqlite3
AUTO_MIGRATE=false

# futures or spot
MARKET=futures

# Defaults for /top and price-alert polling.
TOP_LIMIT=10
ALERT_POLL_SECONDS=30

# Optional screenshot-to-trade recognition for Telegram /open.
# If OPENAI_API_KEY is empty, the bot falls back to the manual /open template.
OPENAI_API_KEY=
OPENAI_VISION_MODEL=gpt-5.5

# Mini App local server.
WEB_APP_URL=http://127.0.0.1:8080
WEB_HOST=127.0.0.1
WEB_PORT=8080
TRADE_UPLOAD_DIR=data/trade_uploads
